import imgD10 from "../../assets/img/10_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D10-IMG_8153.webp";
import imgD11 from "../../assets/img/11_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D11-IMG_8156.webp";
import imgD12 from "../../assets/img/13_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D13-IMG_8159.webp";
import imgD14 from "../../assets/img/14_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D14-IMG_8161.webp";
import imgD13 from "../../assets/img/13_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D13-IMG_8159.webp";
---

<BaseLayout title={title}>
  <HeroBanner
    image={Portrait}
    alt="Portrait de Christophe Boulanger"
    title="Christophe Boulanger"
    subtitle="Artiste multidisciplinaire"
  />

  <Citation
    text="Moi qui suis agité, j'ai appris à prendre le temps de regarder les gens avec tendresse. J'ai appris à dessiner sur les genoux avec deux fois rien. J'ai ré-appris à jouer, gratis. J'ai appris à croquer vite sans même avoir besoin de regarder le papier. "
    author="Christophe Boulanger"
  />
  <hr class="mx-13 sm:mx-13 md:mx-13 lg:mx-32 border-t border-gray-300 mt-10" />
  <div class="m-13">
    {
      Plagistes && (
        <Image
          src={Plagistes}
          alt="Plagistes, Christophe Boulanger"
          format="webp"
          widths={[320, 480, 768, 1024, 1280, 1600, 1920]}
          sizes="(max-width: 600px) 40vw, (max-width: 1200px) 50vw, 33vw"
          layout="constrained"
          width={Plagistes.width}
          height={Plagistes.height}
          quality={60}
          class="w-full h-auto"
        />
      )
    }

    <div class="w-full p-8">
      <h1 class="text-3xl pb-3 italic">Plagistes</h1>
      <p>
        Avec <span class="italic">Plagistes</span>, Christophe nous offre une
        anthologie joyeuse de 10 ans de farniente à croquer les foules des
        plages, sélection de 160 dessins parmi plus de 800 croquis réalisés sur
        le motif. Une édition d'artiste en 150 exemplaires. Une sélection de
        dessins originaux sont également proposés pour une édition <span
          class="italic">augmentée</span
        >
      </p><br />
      <span class="font-bold">Édition limitée à 150 exemplaires</span>
      <br />
      160 dessins inédits <br />
      Format 21 x 30 cm <br />
      Livre relié-cousu
      <br />
      Prix : 40€ (hors frais de port)
      <br />

      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-200 rounded-lg mt-5 hover:bg-zinc-300"
      >
        Acheter ce livre <span class="text-lg">→</span>
      </a>
    </div>
  </div>
  <hr class="mx-13 sm:mx-13 md:mx-13 lg:mx-32 border-t border-gray-300 mt-10" />
  <ArtworkCard
    image={imgD01}
    alt="Plagiste, dessin original, Christophe Boulanger, Villa Sonneville"
    title="Tchin-Tchin"
    year="2025"
    technique="Encre, aquarelle, pastel sur papier"
    dimensions="30 x 40 cm"
    reference="CB-D01"
    price="130€"
    contactUrl="/contact"
  />
