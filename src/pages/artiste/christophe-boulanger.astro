import imgD05 from "../../assets/img/05_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D05-IMG_8169.webp";
import imgD06 from "../../assets/img/06_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D06-IMG_8171.webp";
import imgD07 from "../../assets/img/07_5-7-MD-Christophe-Boulanger-Plagistes-CB-PLAGISTES-D07-IMG_8144.webp";
