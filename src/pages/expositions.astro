---
import { getCollection } from 'astro:content';
import EventBlock from '../components/EventBlock.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Expositions';

// Récupère toutes les expositions, trie par date de début décroissante
// (plus récent en haut). Les expositions sans date_debut tombent à la fin.
const expositions = (await getCollection('expositions')).sort((a, b) => {
  const dA = a.data.date_debut ? a.data.date_debut.getTime() : 0;
  const dB = b.data.date_debut ? b.data.date_debut.getTime() : 0;
  return dB - dA;
});
---

<BaseLayout
  title={title}
  description="Découvrez les expositions en cours et à venir à la Villa Sonneville, maison-galerie d'art à Roubaix : une programmation riche et éclectique d'art contemporain, avec des artistes émergents et confirmés, dans un cadre historique exceptionnel.">
  <h1 class="text-6xl font-bold m-10">
    {title}
  </h1>

  {
    expositions.map((expo, i) => (
      <EventBlock
        statut={expo.data.statut}
        reverse={i % 2 === 1}
        image={expo.data.image}
        caption={expo.data.caption}
        date={expo.data.date}
        title={expo.data.title}
        subtitle={expo.data.subtitle}
        category={expo.data.category}
        description={expo.data.description}
        link={expo.data.link}
        linkLabel={expo.data.linkLabel}
        target_blank={expo.data.target_blank}
      />
    ))
  }
</BaseLayout>
