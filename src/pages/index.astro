---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
import EventBlock from '../components/EventBlock.astro';
import heroImg from '../assets/img/HD-H_DSC9840-Villa-Sonneville-Vue-.jpeg';

const title = 'Accueil';

// On ne récupère que les expositions marquées "à mettre en avant sur la home"
// via la case à cocher du CMS (champ "featured").
const featuredExpos = (
  await getCollection('expositions', ({ data }) => data.featured === true)
).sort((a, b) => {
  const dA = a.data.date_debut ? a.data.date_debut.getTime() : 0;
  const dB = b.data.date_debut ? b.data.date_debut.getTime() : 0;
  return dB - dA;
});
---

<BaseLayout title={title}>
  <HeroBanner
    image={heroImg}
    title="VILLA SONNEVILLE"
    subtitle="Maison - Galerie d'art • Chambres d'hôtes"
    alt="Photo de la Villa Sonneville, galerie d'art à Roubaix"
  />

  {
    featuredExpos.map((expo, i) => (
      <EventBlock
        statut={expo.data.statut}
        reverse={i % 2 === 1}
        image={expo.data.image}
        caption={expo.data.caption}
        date={expo.data.date}
        title={expo.data.title}
        subtitle={expo.data.subtitle}
        category={expo.data.category}
        description={expo.data.description}
        link={expo.data.link}
        linkLabel={expo.data.linkLabel}
        target_blank={expo.data.target_blank}
      />
    ))
  }
</BaseLayout>
