---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import heroImg from "../assets/img/HD-H_DSC9840-Villa-Sonneville-Vue-.jpeg";
import EventBlock from "../components/EventBlock.astro";
import img3 from "../assets/img/image3.jpg";
import img1 from "../assets/img/image1.jpeg";
import img2 from "../assets/img/image2.webp";
import SejourArty from "../components/SejourArty.astro";    
const title = "Accueil";
---

<BaseLayout title={title}>
  <HeroBanner
    image={heroImg}
    title="VILLA SONNEVILLE"
    subtitle="Maison - Galerie d'art • Chambres d'hôtes"
    alt="Photo de la Villa Sonneville, galerie d'art à Roubaix"
  />
  
<SejourArty />
</BaseLayout>
