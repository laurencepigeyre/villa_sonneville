---
export interface Props {
  image: any;
  alt: string;
  title: string;
  year: string;
  technique: string;
  dimensions: string;
  format?: string;
  price?: string;
  contactUrl?: string ;
  reference?: string;
  reverse?: boolean;
}

import { Image } from "astro:assets";

const {
  image,
  alt,
  title,
  year,
  technique,
  dimensions,
  format = "",
  price = "",
  contactUrl = "/contact",
  reference = "",
  reverse = false,
} = Astro.props;

const formatStyles: Record<string, string> = {
  "Très Grand Format": "bg-indigo-200/60 border-indigo-300",
  "Grand Format": "bg-lime-200/60 border-lime-300",
  "Moyen Format": "bg-orange-200/60 border-orange-300",
  "Petit Format": "bg-sky-200/60 border-sky-300",
};
const formatClass = formatStyles[format] ?? "bg-zinc-200/60 border-zinc-300";
---

<div class={`flex flex-col md:flex-row items-center m-5 rounded-lg py-5 px-5 ${reverse ? "md:flex-row-reverse" : ""}`}>
  <!-- IMAGE -->
  <div class="w-full md:w-1/2 px-3 flex items-center justify-center flex-col">
    {
      image && (
        <Image
          src={image}
          alt={alt}
          format="webp"
          widths={[320, 480, 640, 768, 1024]}
          sizes="(max-width: 768px) 100vw, 40vw"
          layout="constrained"
          width={image.width}
          height={image.height}
          quality={70}
          class="w-full h-auto"
        />
      )
    }
  </div>

  <!-- TEXTE -->
  <div class="w-full md:w-1/2 p-8">
    <h1 class="text-3xl pb-3 italic">{title}</h1>

    <p>
      {year}<br />
      {technique}<br />
      {dimensions}<br />
      {reference && <>Réf. {reference}</>}
    </p>

    {
      format && (
        <div class={`px-3 py-1 border rounded-full text-sm mt-3 w-fit ${formatClass}`}>
          {format}
        </div>
      )
    }

    {
      price && (
        <>
          <br />
          Prix : {price}
        </>
      )
    }

    <br />

    <a
      href={contactUrl}
      class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-200 rounded-lg mt-5 hover:bg-zinc-300"
    >
      Cette œuvre m'intéresse <span class="text-lg">→</span>
    </a>
  </div>
</div>
