---
export interface Props {
  image: any;
  alt: string;
  title: string;
  year: string;
  technique: string;
  dimensions: string;
  format?: string;
  price?: string;
  reference?: string;
  contactUrl?: string;
}

import { Image } from "astro:assets";

const {
  image,
  alt,
  title,
  year,
  technique,
  dimensions,
  format = "",
  price = "",
  reference = "",
  contactUrl = "/contact",
} = Astro.props;

const formatStyles: Record<string, string> = {
  "Très Grand Format": "bg-indigo-200/60 border-indigo-300",
  "Grand Format": "bg-lime-200/60 border-lime-300",
  "Moyen Format": "bg-orange-200/60 border-orange-300",
  "Petit Format": "bg-sky-200/60 border-sky-300",
};
const formatClass = formatStyles[format] ?? "bg-zinc-200/60 border-zinc-300";
---

<div class=" py-5 px-5 flex flex-col">
  <!-- IMAGE -->
  <div class="w-full flex items-center justify-center flex-col">
    <Image
      src={image}
      alt={alt}
      format="webp"
      widths={[320, 480, 600]}
      sizes="(max-width: 768px) 100vw, 308px"
      layout="constrained"
      quality={60}
      class="w-full h-auto"
    />
  </div>

  <!-- TEXTE -->
  <div class="p-5">
    <h1 class="text-2xl pb-3 italic">{title}</h1>

    <p>
      {year}<br />
      {technique}<br />
      {dimensions}<br />
      {reference && <>Réf. {reference}</>}
    </p>

    {
      format && (
        <div class={`px-3 py-1 border rounded-full text-sm mt-3 w-fit ${formatClass}`}>
          {format}
        </div>
      )
    }

    {price && (
      <>
        <br />
        Prix : {price}
      </>
    )}

    <br />

    <a
      href={contactUrl}
      class="inline-flex items-center gap-2 px-6 py-3 bg-zinc-200 rounded-lg mt-5 hover:bg-zinc-300"
    >
      Cette œuvre m'intéresse <span class="text-lg">→</span>
    </a>
  </div>
</div>
