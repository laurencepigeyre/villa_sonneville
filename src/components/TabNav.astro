---
/**
 * TabNav — Barre d'onglets réutilisable
 *
 * Usage dans la page :
 * ─────────────────────────────────────────────
 *   <TabNav
 *     tabs={[
 *       { label: "Biographie", key: "bio" },
 *       { label: "Œuvres",     key: "oeuvres" },
 *     ]}
 *     defaultKey="bio"
 *     groupId="cb"
 *   />
 *
 *   <div data-tab-panel="bio" data-tab-group="cb">…</div>
 *   <div data-tab-panel="oeuvres" data-tab-group="cb" class="hidden">…</div>
 */

export interface Tab {
  label: string;
  key: string;
}

export interface Props {
  tabs: Tab[];
  defaultKey?: string;
  groupId?: string;
}

const { tabs, defaultKey, groupId = 'tabs' } = Astro.props;
const activeKey = defaultKey ?? tabs[0]?.key;
---

<nav
  class="tab-nav flex mx-5 lg:mx-32 mt-10 mb-0"
  role="tablist"
  aria-label="Navigation par onglets"
  data-tab-group={groupId}>
  {
    tabs.map(({ label, key }) => (
      <button
        role="tab"
        aria-selected={key === activeKey ? 'true' : 'false'}
        data-tab-btn={key}
        data-tab-group={groupId}
        data-active={key === activeKey ? 'true' : 'false'}>
        {label}
      </button>
    ))
  }
</nav>

<style>
  .tab-nav {
    border-bottom: 1px solid #e5e7eb;
  }

  .tab-nav button {
    position: relative;
    padding: 0.75rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.025em;
    transition: color 0.2s;
    outline: none;
    border: none;
    background: transparent;
    cursor: pointer;
    color: #9ca3af; /* gray-400 */
    /* Le soulignement actif est géré via box-shadow pour éviter
       tout décalage de layout lié à border-bottom */
    box-shadow: none;
    margin-bottom: -1px;
  }

  .tab-nav button:hover {
    color: #374151; /* gray-700 */
  }

  .tab-nav button[data-active='true'] {
    color: #111827; /* gray-900 */
    box-shadow: inset 0 -2px 0 0 #111827;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('nav[data-tab-group]').forEach((nav) => {
    const groupId = nav.dataset.tabGroup!;

    const buttons = nav.querySelectorAll<HTMLButtonElement>('[data-tab-btn]');
    const panels = document.querySelectorAll<HTMLElement>(`[data-tab-panel][data-tab-group="${groupId}"]`);

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetKey = btn.dataset.tabBtn!;

        // Reset tous les onglets
        buttons.forEach((b) => {
          b.setAttribute('aria-selected', 'false');
          b.dataset.active = 'false';
        });

        // Masquer tous les panneaux
        panels.forEach((p) => p.classList.add('hidden'));

        // Activer l'onglet cliqué
        btn.setAttribute('aria-selected', 'true');
        btn.dataset.active = 'true';

        // Afficher le panneau correspondant
        document
          .querySelector<HTMLElement>(`[data-tab-panel="${targetKey}"][data-tab-group="${groupId}"]`)
          ?.classList.remove('hidden');
      });
    });
  });
</script>
